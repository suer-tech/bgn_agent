# LLM Provider: "openrouter", "antigravity", "manual", or "opencode"
LLM_PROVIDER=antigravity

# Model ID for OpenRouter (used only when LLM_PROVIDER=openrouter)
LLM_MODEL=openai/gpt-4o

# OpenRouter API credentials (used only when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# BitGN benchmark host
BENCHMARK_HOST=https://api.bitgn.com

# Benchmark ID: "bitgn/sandbox" or "bitgn/pac1-dev"
BENCHMARK_ID=bitgn/pac1-dev
